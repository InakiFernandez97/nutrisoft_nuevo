# Archivo de configuración de entorno
# Copiar este archivo como .env y configurar con los valores correctos

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nutrisoft
DB_USER=root
DB_PASS=

# URL base del sitio
BASE_URL=http://nutrisoft.test/

# Zona horaria
TIMEZONE=America/Santiago

# Modo de desarrollo (true/false)
DEBUG_MODE=false
